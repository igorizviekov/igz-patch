DATABASE_URL="postgres://postgres:postgres@localhost:5432/igzpatch"
GITHUB_WEBHOOK_SECRET="replace-me"
GITHUB_APP_ID="123456"
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
IGZPATCH_DASHBOARD_PASSWORD="replace-with-a-long-random-password"
# Control-plane opt-in: allow any GitHub user to queue the configured fix command.
IGZPATCH_ALLOW_PUBLIC_FIX_COMMANDS="false"

# Optional worker-wide override. Otherwise .igzpatch.yml selects the provider and model.
IGZPATCH_AGENT_PROVIDER="codex"
IGZPATCH_AGENT_MODEL="gpt-5.4"

# Codex provider. Docker execution requires CODEX_API_KEY.
# IGZPATCH_CODEX_BIN is retained for direct adapter development and tests.
IGZPATCH_CODEX_BIN="codex"
IGZPATCH_CODEX_IMAGE="igzpatch/codex-agent:0.1.0"
CODEX_API_KEY=""

# Docker sandbox runtime.
IGZPATCH_DOCKER_BIN="docker"
IGZPATCH_ALLOWED_SANDBOX_IMAGES="node:22-bookworm"
# Networked dependency setup is disabled unless the worker operator explicitly opts in.
IGZPATCH_ALLOW_SETUP_NETWORK="false"

# OpenAI Responses API provider.
OPENAI_API_KEY=""
IGZPATCH_OPENAI_BASE_URL="https://api.openai.com/v1"

IGZPATCH_WORKER_ID="local-worker"
IGZPATCH_POLL_INTERVAL_MS="5000"
IGZPATCH_LEASE_MS="600000"
