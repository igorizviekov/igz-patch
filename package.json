{
  "name": "igz-patch",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "worker": "tsx src/worker/index.ts",
    "worker:once": "tsx src/worker/index.ts --once",
    "docker:build-agent": "docker build -f docker/codex-agent.Dockerfile -t igzpatch/codex-agent:0.1.0 .",
    "db:init": "psql \"$DATABASE_URL\" -f db/schema.sql",
    "test": "tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@octokit/app": "^15.1.0",
    "@octokit/rest": "^21.1.1",
    "dotenv": "^17.4.2",
    "next": "^16.0.0",
    "postgres": "^3.4.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "yaml": "^2.6.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
